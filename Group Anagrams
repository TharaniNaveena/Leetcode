class Solution:
    def groupAnagrams(self, strs: List[str]) -> List[List[str]]:
        
        if len(strs)<= 0:
            return []
        data_map = defaultdict(list)

        for word in strs:
            arr = [0] * 26

            for c in word:
                arr[ord(c) - ord("a")] += 1
            data_map[tuple(arr)].append(word)

        return list(data_map.values())
